{
  "name": "react-native-swiftui-dsl",
  "version": "0.1.1",
  "description": "A SwiftUI-inspired declarative DSL for building React Native UIs with chainable modifiers, theme system, and two-way bindings.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src/"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage --collectCoverageFrom='src/**/*.{ts,tsx}'"
  },
  "keywords": [
    "react-native",
    "swiftui",
    "dsl",
    "declarative",
    "ui",
    "builder",
    "modifiers",
    "theme",
    "expo"
  ],
  "author": "Andrew Kochulab <andrew.kochulab@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AndrewKochulab/react-native-swiftui-dsl.git"
  },
  "homepage": "https://github.com/AndrewKochulab/react-native-swiftui-dsl#readme",
  "bugs": {
    "url": "https://github.com/AndrewKochulab/react-native-swiftui-dsl/issues"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "react-native-safe-area-context": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@expo/vector-icons": {
      "optional": true
    },
    "expo-router": {
      "optional": true
    }
  },
  "devDependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.0.0",
    "babel-preset-expo": "^55.0.10",
    "expo": "^55.0.4",
    "expo-router": "~6.0.23",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.8.0"
  },
  "jest": {
    "preset": "jest-expo",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/__tests__/Helpers/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|native-base|react-native-svg)"
    ],
    "coveragePathIgnorePatterns": [
      "src/index.ts",
      "src/Theme/types.ts"
    ]
  }
}
